<div class="container text-center py-5">
  <h1 class="display-4 fw-bold mb-3">
    Learn History with AI 🏛️
  </h1>
  <p class="lead text-muted mb-4">
    Pick a topic, ask quetions, and get simple explnations
    — built for secondary school students.
  </p>
  <% if user_signed_in? %>
    <%= link_to "Browse Topics", topics_path, class: "btn btn-primary btn-lg" %>
  <% else %>
    <%= link_to "Get Started", new_user_registration_path, class: "btn btn-primary btn-lg me-2" %>
    <%= link_to "Log in", new_user_session_path, class: "btn btn-outline-secondary btn-lg" %>
  <% end %>
</div>
